# ============================================================
# 博客项目环境变量
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================

# ——— 服务器 ———
PORT=3000
NODE_ENV=development

# ——— 数据库 (PostgreSQL) ———
# 连接池参数说明：
#   connection_limit=10       最大连接数
#   connect_timeout=10        连接超时（秒）
#   pool_timeout=20           等待池连接超时（秒）
#   statement_cache_size=1000 预编译语句缓存数量
DATABASE_URL=postgresql://postgres:123456@localhost:5432/blog?schema=public&connection_limit=10&connect_timeout=10&pool_timeout=20&statement_cache_size=1000
DATABASE_POOL_SIZE=10
DATABASE_CONNECTION_TIMEOUT=10000

# ——— Redis ———
REDIS_URL=redis://localhost:6379
# 设为 true 可完全禁用 Redis（回退到内存缓存）
SKIP_REDIS=false

# ——— JWT 认证 ———
JWT_SECRET=your-secret-key-change-me

# ——— CORS 跨域 ———
# 开发环境自动允许 localhost:3000/5500，无需额外配置
# 生产环境：逗号分隔的允许域名
FRONTEND_URL=http://localhost:3000
# ALLOWED_ORIGINS=https://myblog.com,https://www.myblog.com
# 部署在 cyclic.app 时启用
# ALLOW_CYCLIC=true

# ——— OAuth 第三方登录 ———
# GitHub OAuth App: https://github.com/settings/developers
#   Homepage URL: http://localhost:3000
#   Callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Google OAuth 2.0: https://console.cloud.google.com/apis/credentials
#   需先安装: npm install passport-google-oauth20
#   Redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ——— SMTP 邮件（订阅通知等功能） ———
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ——— 站点 ———
SITE_NAME=个人博客
SITE_URL=http://localhost:3000

# ——— 日志 ———
LOG_LEVEL=info
# 生产环境日志文件目录（不设置则仅输出到控制台）
# LOG_DIR=/var/log/blog

# ——— Docker Compose（本地开发用） ———
# DB_USER=postgres
# DB_PASSWORD=123456
# DB_NAME=blog

# ——— 备份恢复 ———
# 本地备份存储目录（默认 ./backups）
# BACKUP_DIR=/var/backups/blog
# 保留策略
# BACKUP_KEEP_DAILY=7
# BACKUP_KEEP_WEEKLY=4
# 备份告警通知邮箱
# BACKUP_NOTIFY_EMAIL=admin@example.com
# 磁盘空间告警阈值（GB），剩余空间低于此值时发送告警
# BACKUP_SPACE_ALERT_GB=5
# ——— 远程备份存储（S3/MinIO/OSS） ———
# BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_BUCKET=blog-backups
# BACKUP_S3_ACCESS_KEY=your-access-key
# BACKUP_S3_SECRET_KEY=your-secret-key

# ——— 特性开关 ———
# 全局开关，设为 false 可完全禁用特性开关系统（所有 flag 返回 false）
FEATURE_FLAGS_ENABLED=true
# Redis 缓存 TTL（秒）
# FEATURE_FLAG_CACHE_TTL=300
# FEATURE_FLAG_CACHE_ALL_TTL=600
# FEATURE_FLAG_CACHE_CONFIG_TTL=3600

# ——— 数据加密 ———
# 生成 AES-256 加密密钥: node -e "console.log('v1:' + require('crypto').randomBytes(32).toString('hex'))"
# 格式: v{版本号}:{64位十六进制字符}
ENCRYPTION_KEY=v1:
# 可选：密钥派生盐值（32位十六进制），不设置则使用默认盐
ENCRYPTION_IV=
# 可选：密钥轮换时填写旧版本密钥（仅用于解密已有数据，逗号分隔）
# ENCRYPTION_PREVIOUS_KEYS=v0:旧密钥64位十六进制
