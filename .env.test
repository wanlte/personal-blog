# ============================================================
# 测试环境配置
# ============================================================

# ——— 服务器 ———
PORT=3000
NODE_ENV=test

# ——— 数据库（使用独立测试数据库） ———
DATABASE_URL=postgresql://postgres:123456@localhost:5432/blog_test?schema=public
DATABASE_POOL_SIZE=10
DATABASE_CONNECTION_TIMEOUT=10000

# ——— Redis（测试环境默认禁用） ———
SKIP_REDIS=true

# ——— JWT ———
JWT_SECRET=test-secret-key-2024

# ——— 站点 ———
SITE_NAME=个人博客（测试）
SITE_URL=http://localhost:3000

# ——— 日志 ———
LOG_LEVEL=silent

# ——— 数据加密（测试用密钥，勿用于生产） ———
ENCRYPTION_KEY=v1:test1234test1234test1234test1234test1234test1234test1234test1234
ENCRYPTION_IV=test_iv_2026_test_encryption_iv_
