// prisma/schema.prisma
// PostgreSQL 数据库 schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

// 用户表
model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(255)
  password      String?   @db.VarChar(255)
  email         String?   @unique @db.VarChar(320)
  avatar        String?   @db.VarChar(500)
  oauthProvider String?   @map("oauth_provider") @db.VarChar(20)
  oauthId       String?   @map("oauth_id") @db.VarChar(100)
  idCard        String?   @map("id_card") @db.Text
  bankCard      String?   @map("bank_card") @db.Text
  secretQuestion String?  @map("secret_question") @db.Text
  isAdmin       Boolean   @default(false) @map("is_admin")
  role          String?   @db.VarChar(30) // super_admin | content_admin | analyst
  createdAt     DateTime  @default(now()) @map("created_at")

  // 关联
  articles        Article[]
  comments        Comment[]
  subscriptions   UserSubscription[]
  payments        PaymentRecord[]
  likes           ArticleLike[]
  collections     ArticleCollection[]
  followers       UserFollow[]    @relation("Followers")
  following       UserFollow[]    @relation("Following")
  purchases       ArticlePurchase[]
  creatorProfile  CreatorProfile?
  apiKeys         ApiKey[]
  adminLogs       AdminLog[]
  auditLogs       AuditLog[]

  @@unique([oauthProvider, oauthId])
  @@map("users")
}

// 文章表
model Article {
  id        Int       @id @default(autoincrement())
  title     String    @db.VarChar(255)
  content   String?   @db.Text
  summary   String?   @db.Text
  userId    Int?      @map("user_id")
  views     Int       @default(0)
  status    String    @default("published") @map("status") @db.VarChar(20)
  isPinned  Int       @default(0) @map("is_pinned")
  isPaid    Int       @default(0) @map("is_paid")
  price     Decimal?  @default(0) @db.Decimal(10, 2)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // 关联
  user      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  comments  Comment[]
  tags      ArticleTag[]
  likes     ArticleLike[]
  collections ArticleCollection[]
  purchases ArticlePurchase[]

  @@map("articles")
}

// 标签表
model Tag {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(100)
  createdAt DateTime  @default(now()) @map("created_at")
  
  // 关联
  articles  ArticleTag[]

  @@map("tags")
}

// 文章-标签关联表（多对多）
model ArticleTag {
  articleId Int       @map("article_id")
  tagId     Int       @map("tag_id")
  
  // 关联
  article   Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

// 评论表（支持嵌套回复）
model Comment {
  id        Int       @id @default(autoincrement())
  content   String    @db.Text
  articleId Int       @map("article_id")
  userId    Int?      @map("user_id")
  userName  String?   @map("user_name") @db.VarChar(100)
  parentId  Int?      @map("parent_id")
  status    String    @default("approved") @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")

  // 关联
  article   Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  parent    Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  replies   Comment[]  @relation("CommentReplies")

  @@index([articleId])
  @@index([parentId])
  @@map("comments")
}

// 文章点赞表
model ArticleLike {
  id        Int      @id @default(autoincrement())
  articleId Int      @map("article_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
  @@map("article_likes")
}

// 文章收藏表
model ArticleCollection {
  id        Int      @id @default(autoincrement())
  articleId Int      @map("article_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
  @@map("article_collections")
}

// 用户关注表
model UserFollow {
  id          Int      @id @default(autoincrement())
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("user_follows")
}

// 文章付费阅读购买记录
model ArticlePurchase {
  id        Int      @id @default(autoincrement())
  articleId Int      @map("article_id")
  userId    Int      @map("user_id")
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
  @@map("article_purchases")
}

// 创作者信息（扩展用户）
model CreatorProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique @map("user_id")
  bio         String?  @db.Text
  avatar      String?  @db.VarChar(500)
  isVerified  Boolean  @default(false) @map("is_verified")
  totalEarnings Decimal? @default(0) @map("total_earnings") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("creator_profiles")
}

// 订阅方案表
model SubscriptionPlan {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(50)
  price        Decimal   @db.Decimal(10, 2)
  durationDays Int       @map("duration_days")
  features     Json      @default("[]")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  
  // 关联
  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

// 用户订阅表
model UserSubscription {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  planId    Int       @map("plan_id")
  status    String    @default("active") @map("status") @db.VarChar(20) // active, expired, cancelled
  startDate DateTime  @map("start_date")
  endDate   DateTime  @map("end_date")
  createdAt DateTime  @default(now()) @map("created_at")
  
  // 关联
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  
  // 索引
  @@index([userId])
  @@index([status])
  @@map("user_subscriptions")
}

// 支付记录表
model PaymentRecord {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  subscriptionId Int?      @map("subscription_id")
  amount        Decimal   @db.Decimal(10, 2)
  paymentMethod String    @map("payment_method") @db.VarChar(50)
  status        String    @default("pending") @map("status") @db.VarChar(20) // pending, completed, failed, refunded
  transactionId String?   @map("transaction_id") @db.VarChar(100)
  createdAt     DateTime  @default(now()) @map("created_at")
  
  // 关联
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payment_records")
}

// 第三方 API 密钥表（加密存储）
model ApiKey {
  id          Int       @id @default(autoincrement())
  serviceName String    @map("service_name") @db.VarChar(50)
  apiKey      String    @map("api_key") @db.Text
  description String?   @db.VarChar(255)
  userId      Int?      @map("user_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([serviceName, userId])
  @@index([userId])
  @@map("api_keys")
}

// 密钥轮换日志表
model KeyRotationLog {
  id          Int       @id @default(autoincrement())
  oldVersion  String    @map("old_version") @db.VarChar(10)
  newVersion  String    @map("new_version") @db.VarChar(10)
  rotatedAt   DateTime  @default(now()) @map("rotated_at")
  rotatedBy   String?   @map("rotated_by") @db.VarChar(100)
  notes       String?   @db.VarChar(500)

  @@map("key_rotation_logs")
}

// 管理员操作日志表
model AdminLog {
  id        Int       @id @default(autoincrement())
  adminId   Int       @map("admin_id")
  action    String    @db.VarChar(50)
  target    String?   @db.VarChar(100)
  details   String?   @db.Text
  ip        String?   @db.VarChar(45)
  createdAt DateTime  @default(now()) @map("created_at")

  admin     User      @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_logs")
}

// 系统配置表（键值存储）
model SystemSetting {
  id        Int       @id @default(autoincrement())
  key       String    @unique @db.VarChar(100)
  value     String    @db.Text
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("system_settings")
}

// 特性开关配置表（灰度发布 / Feature Flags）
model FeatureFlag {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(100)
  enabled    Boolean   @default(false)
  percentage Int?      @default(0)
  userIds    Json?     @default("[]")
  roles      String?   @db.VarChar(200)
  startDate  DateTime? @map("start_date")
  endDate    DateTime? @map("end_date")
  updatedBy  Int?      @map("updated_by")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("feature_flags")
}

// 操作审计日志表
model AuditLog {
  id           Int       @id @default(autoincrement())
  userId       Int?      @map("user_id")
  action       String    @db.VarChar(50)
  resourceType String    @map("resource_type") @db.VarChar(30)
  resourceId   String?   @map("resource_id") @db.VarChar(50)
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  userAgent    String?   @map("user_agent") @db.Text
  oldValue     Json?     @map("old_value")
  newValue     Json?     @map("new_value")
  metadata     Json?     @default("{}")
  duration     Int?
  createdAt    DateTime  @default(now()) @map("created_at")

  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
